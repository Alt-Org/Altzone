  _avaritiaAvatar:
    _nameFinnish: Omistuksenvartija
    _nameEnglish: The Hoardwarden
    _eyeColor: {r: 0.8, g: 0.8, b: 0, a: 1}
    _skinColor: {r: 0.9098039, g: 0.7607843, b: 0.61960787, a: 1}
    _frame: {fileID: 21300000, guid: 7f70ad98f7f01db41bafe5dd07c3fd35, type: 3}
    _cornerIcon: {fileID: 21300000, guid: 6e84e4c3a2d400f438be437826ed5abd, type: 3}
    _character: {fileID: 21300000, guid: cd33d7546312a7747acf3596094ed4d7, type: 3}
    _descFinnish: "Olen aina paikalla, kun jotain on otettavissa. En ker\xE4\xE4
      itsekkyyden vuoksi. Maailma on arvaamaton ja vain hyvin varautunut selviytyy."
    _descEnglish: 'I am always present when something can be taken. I do not gather
      out of selfishness. The world is unpredictable, and only the well-prepared
      survive. '
