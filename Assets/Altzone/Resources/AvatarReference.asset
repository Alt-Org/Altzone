      BodyId: 3130001
      HandsId: 3200000
      FeetId: 3370101
      AlternativeVariations: []
  _luxuriaAvatar:
    _nameFinnish: Vietinvartija
    _nameEnglish: The Longingwarden
    _eyeColor: {r: 0.78039217, g: 0.08235294, b: 0.52156866, a: 1}
