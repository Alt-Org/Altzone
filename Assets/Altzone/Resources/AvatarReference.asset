  _invidiaAvatar:
    _nameFinnish: Vertailunvartija
    _nameEnglish: The Gazewarden
    _eyeColor: {r: 0.13333334, g: 0.54509807, b: 0.13333334, a: 1}
    _skinColor: {r: 0.54509807, g: 0.5647059, b: 0.5686275, a: 1}
    _frame: {fileID: 21300000, guid: a85f88f04776d5140bd521112cdb8a26, type: 3}
    _cornerIcon: {fileID: 21300000, guid: afc086fe899f85f4ca33ba72d38a607b, type: 3}
    _character: {fileID: 21300000, guid: 2ee31512d109cfe4e8576046cbbaa0a1, type: 3}
    _descFinnish: "Pid\xE4n toiset katseeni alla, jotta kukaan ei nouse minua ylemm\xE4s.
      Voitto on sit\xE4, kun heid\xE4n aarteensa lakkaavat loistamasta omaani kirkkaammin."
    _descEnglish: I keep others under my gaze so no one rises above me. Victory is
      when their treasures no longer shine brighter than mine.
    _default:
      CharacterName: Default Character
      CharacterId: 300
      HairId: 1030001
      EyesId: 2130101
