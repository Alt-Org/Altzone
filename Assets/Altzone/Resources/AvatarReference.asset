  _acediaAvatar:
    _nameFinnish: Levonvartija
    _nameEnglish: The Stillwarden
    _eyeColor: {r: 0.4392157, g: 0.5019608, b: 0.5647059, a: 1}
    _skinColor: {r: 0.7254902, g: 0.7254902, b: 0.7254902, a: 1}
