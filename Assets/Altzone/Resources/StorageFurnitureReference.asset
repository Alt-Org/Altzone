  - SetName: Schrodinger
    SetNameEnglish: Schrodinger
    SetRibbonBackground: {fileID: 21300000, guid: 27597e8ec0e75f34c94640b894778d1b,
      type: 3}
    SetPosterBackground: {fileID: 21300000, guid: 44a2ac664637fda45b53d434f28d8ca8,
