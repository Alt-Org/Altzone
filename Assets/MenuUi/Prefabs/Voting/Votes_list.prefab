--- !u!114 &7048239012223655170
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1299545118275546062}
  m_Enabled: 0
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 220ef737e6ba13e48841e379d56ad79b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _finnishText: "Yhteiset p\xE4\xE4t\xF6kset tehd\xE4\xE4n t\xE4\xE4ll\xE4!\r\nKun
    ehdotat ostosta kaupasta tai muutosta kivilinnayhteis\xF6si asetuksiin, ne ratkaistaan
    t\xE4\xE4ll\xE4 demokraattisesti.\r\nOle ensimm\xE4inen, joka aloittaa \xE4\xE4nestyksen
    ja vie yhteis\xF6\xE4si eteenp\xE4in!"
  _englishText: "Shared decisions are made here!\r\nWhen you propose a purchase from
    the shop or a change in your Stonecastle community\u2019s settings, they are
    decided here \u2014 democratically.\r\nBe the first to start a vote and lead
    your community forward!"
