  m_MultiSelect: 0
  m_Options:
    m_Options:
    - m_Text: "Miksi t\xE4m\xE4 on arvokas sinulle?"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: "\u2022 Tykk\xE4\xE4n tuotteen ulkoasusta"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: "\u2022 Ostos on edullinen"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: "\u2022 Hinnalla ei ole v\xE4li\xE4"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: "\u2022 Klaanin yhteinen p\xE4\xE4t\xF6s"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: "\u2022 Haluan erottua paremmin"
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_OnValueChanged:
    m_PersistentCalls:
      m_Calls: []
